GLM_API_KEY=replace-with-your-model-api-key
DS_THINK_BASE_URL=https://open.bigmodel.cn/api/paas/v4
DS_THINK_MODEL=GLM-4.5-AIR
DS_QUICK_BASE_URL=https://open.bigmodel.cn/api/paas/v4
DS_QUICK_MODEL=GLM-4.5-AIR

SILICONFLOW_API_KEY=replace-with-your-embedding-api-key
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIMENSION=1024

FILE_DIR=/app/docs
RUNTIME_DATA_DIR=/app/var/runtime
UPLOAD_MAX_SIZE_MB=20

MILVUS_ADDRESS=your-milvus-host:19530
MYSQL_DSN=user:password@tcp(your-rds-host:3306)/dbname?charset=utf8mb4&parseTime=True&loc=Local
PROMETHEUS_ADDRESS=http://your-prometheus-host:9090
MCP_LOG_URL=http://your-mcp-server:8080
LOG_TOPIC_REGION=
LOG_TOPIC_ID=

AUTH_ENABLED=true
AUTH_JWT_SECRET=replace-with-a-32-char-secret
AUTH_TOKEN_EXPIRY_HOURS=24
AUTH_RATE_LIMIT_PER_MINUTE=20
AUTH_RATE_LIMIT_BURST=30

CORS_ALLOWED_ORIGIN=https://your-domain.example.com

